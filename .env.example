## ====================================================================
## Bitflix LP — variaveis de ambiente
##
## Copie para .env (nunca commitar) e preencha valores reais.
## Permissoes recomendadas: chmod 0640 .env
##
## Gerar segredos fortes:
##   openssl rand -hex 32
## ====================================================================

# ---- App / Next ----
# NODE_ENV NAO deve ser setado aqui — Next CLI define automaticamente
# (next dev = development, next build/start = production).
#
# PAYLOAD_PUBLIC_SERVER_URL = host do admin Payload (CMS).
#   Usado pelo Payload em CSRF allowlist + cors + admin URL.
# NEXT_PUBLIC_SITE_URL = host do site publico.
#   Usado em sitemap.xml, robots.txt, RSS feed, metadataBase Open Graph.
# Em prod sao subdominios diferentes; em dev local podem ser iguais.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3023
NEXT_PUBLIC_SITE_URL=http://localhost:3023

# ---- Postgres (compose interno) ----
POSTGRES_DB=bitflix_lp
POSTGRES_USER=bitflix_lp
POSTGRES_PASSWORD=CHANGE_ME_postgres
DATABASE_URI=postgres://bitflix_lp:CHANGE_ME_postgres@bitflix-lp-postgres:5432/bitflix_lp

# ---- Payload ----
PAYLOAD_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ---- MinIO (root credentials — admin do MinIO) ----
MINIO_ROOT_USER=minio_root
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password

# ---- S3 (credenciais da app, dedicadas ao bucket) ----
S3_ENDPOINT=http://bitflix-lp-minio:9000
S3_ACCESS_KEY=bitflix_lp_app
S3_SECRET_KEY=CHANGE_ME_s3_app_key
S3_BUCKET=bitflix-lp-staging-media
S3_REGION=us-east-1

# ---- Blog import token (usado pelo endpoint /api/blog-import) ----
BLOG_IMPORT_TOKEN=CHANGE_ME_strong_token

# ---- Analytics (Umami self-hosted) ----
# Criar website em https://stats.bitflix.com.br/dashboard e copiar o ID aqui.
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=https://stats.bitflix.com.br/script.js

# ---- LLM (skill /blog-import) ----
LLM_API_KEY=
