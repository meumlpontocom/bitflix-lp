## ====================================================================
## Bitflix LP — variaveis de ambiente PRODUÇÃO (tomahawk)
##
## Copie para .env.production e preencha valores reais.
## NUNCA commitar .env.production. Permissoes recomendadas: chmod 0640.
##
## Gerar segredos fortes:
##   openssl rand -hex 32
##
## Invocação compose:
##   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
## ====================================================================

# ---- App / Next ----
# PAYLOAD_PUBLIC_SERVER_URL = host do admin Payload (CMS).
# NEXT_PUBLIC_SITE_URL = host do site público apex.
PAYLOAD_PUBLIC_SERVER_URL=https://cms.bitflix.com.br
NEXT_PUBLIC_SITE_URL=https://bitflix.com.br

# ---- Postgres EXTERNO (VM 192.168.14.20:6432) ----
# Sem POSTGRES_* (não temos container postgres em prod). Apenas DATABASE_URI.
DATABASE_URI=postgres://bitflix_lp_prod:00d5499b066c2b0c3ee1b5e398fbd57a1cdca695c2457ff0@192.168.14.20:6432/bitflix_lp_prod

# ---- Payload ----
PAYLOAD_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ---- MinIO (root credentials — admin do MinIO container) ----
MINIO_ROOT_USER=minio_root
MINIO_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand_hex_24

# ---- S3 (credenciais da app, dedicadas ao bucket) ----
# S3_ENDPOINT é fixo no compose pro hostname interno. Não setar aqui.
S3_ACCESS_KEY=bitflix_lp_app
S3_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_24
S3_BUCKET=bitflix-lp-media
S3_REGION=us-east-1

# ---- Blog import token (usado pelo endpoint /api/blog-import) ----
BLOG_IMPORT_TOKEN=CHANGE_ME_use_openssl_rand_hex_32

# ---- Analytics (Umami self-hosted) ----
# Criar website em https://stats.bitflix.com.br/dashboard apontando pra https://bitflix.com.br
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=https://stats.bitflix.com.br/script.js

# ---- LLM (skill /blog-import) ----
LLM_API_KEY=
